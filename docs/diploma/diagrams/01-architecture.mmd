%% Рисунок 2.1 — Загальна архітектура веб-системи RAG-пошуку
flowchart LR
    subgraph Client["Клієнт (Next.js)"]
        Browser["Веб-браузер<br/>React 19 + Tailwind"]
        MW["Edge middleware<br/>(auth + CSP nonce)"]
    end

    subgraph Backend["Сервер (FastAPI)"]
        API["API шар<br/>/api/v1/*"]
        Services["Сервіси<br/>RAG / Auth / Audit"]
        Pipeline["RAG-конвеєр"]
    end

    subgraph Storage["Сховище"]
        Mongo[("MongoDB Atlas<br/>users, documents,<br/>chunks, audit_logs")]
        Vector[("Atlas Vector<br/>Search index")]
    end

    subgraph External["Зовнішні сервіси"]
        LLM["Deepseek API<br/>(LLM)"]
        Embed["FastEmbed<br/>(локально)"]
    end

    Browser <-->|HTTPS / SSE| API
    Browser <--> MW
    API --> Services
    Services --> Pipeline
    Pipeline -->|векторний пошук| Vector
    Services <--> Mongo
    Vector --> Mongo
    Pipeline -->|генерація| LLM
    Pipeline -->|вбудовування| Embed
