%% Рисунок 2.3 — Конвеєр обробки документа
flowchart TD
    Upload([Завантажений файл<br/>PDF / DOCX / XLSX / TXT])
    Validate{"Валідація<br/>(MIME, розмір,<br/>ZIP-bomb)"}
    Parse["Парсинг<br/>(pdfplumber /<br/>python-docx /<br/>openpyxl)"]
    Classify["LLM-класифікатор<br/>типу документа"]
    Context["Контекстуалізація<br/>(Anthropic-style<br/>doc summary)"]

    Schedule["Schedule extractor<br/>(детермінований<br/>+ LLM-уточнення)"]
    Regulation["Regulation extractor<br/>(розбиття за<br/>статтями/пунктами)"]
    Curriculum["Curriculum extractor<br/>(розбиття за<br/>модулями/темами)"]
    Prose["Prose extractor<br/>(рекурсивне<br/>семантичне розбиття)"]

    Embed["FastEmbed<br/>(multilingual-e5-large<br/>з префіксом 'passage:')"]
    Store[("MongoDB Atlas<br/>document_chunks")]

    Upload --> Validate
    Validate -->|OK| Parse
    Validate -->|FAIL| Reject([400 Bad Request])
    Parse --> Classify
    Classify --> Context
    Context --> Schedule
    Context --> Regulation
    Context --> Curriculum
    Context --> Prose
    Schedule --> Embed
    Regulation --> Embed
    Curriculum --> Embed
    Prose --> Embed
    Embed --> Store
