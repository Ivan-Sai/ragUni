%% Рисунок 2.4 — Триетапний конвеєр пошуку відповідей (RAG)
flowchart TD
    Query([Запит користувача<br/>+ історія діалогу])

    subgraph Stage1["Етап 1: Аналіз запиту"]
        Analyzer["query_analyzer<br/>(LLM, нульова T)"]
        Fallback["keyword fallback<br/>(regex, словник)"]
        Analysis{"QueryAnalysis<br/>intent / entities /<br/>strategies / target_doc_types"}
    end

    subgraph Stage2["Етап 2: Мультистратегічне отримання"]
        Structured["structured_retriever<br/>(точний фільтр)"]
        Vector["_run_vector<br/>(MongoDB Atlas<br/>+ pre_filter<br/>+ score threshold)"]
        Hybrid["_run_hybrid<br/>(vector + BM25)"]
        RRF["Reciprocal Rank Fusion<br/>(k=60)"]
    end

    subgraph Stage3["Етап 3: Перерейтинг"]
        Reranker["LLM cross-encoder<br/>(оцінка 0..10)"]
        Filter["Поріг релевантності<br/>(score < 1.0 → drop)"]
    end

    subgraph Stage4["Етап 4: Генерація"]
        NoAnsw{"Контекст<br/>достатній?"}
        Format["Формування контексту<br/>+ нумеровані [N]"]
        Generate["LLM генерація<br/>(Deepseek)"]
        Stream["SSE-стрімінг клієнту"]
        SafeAnsw["Захищена відповідь<br/>'Не можу знайти відповідь...'"]
    end

    Query --> Analyzer
    Analyzer -.->|timeout / error| Fallback
    Analyzer --> Analysis
    Fallback --> Analysis
    Analysis --> Structured
    Analysis --> Vector
    Analysis --> Hybrid
    Structured --> RRF
    Vector --> RRF
    Hybrid --> RRF
    RRF --> Reranker
    Reranker --> Filter
    Filter --> NoAnsw
    NoAnsw -->|так| Format
    NoAnsw -->|ні| SafeAnsw
    Format --> Generate
    Generate --> Stream
