# =============================================================================
# ragUni backend — environment variable reference (.env template)
# =============================================================================
# Copy to ``.env`` and fill in real values. Anything left commented uses the
# default from ``app/config.py``. Required values are marked REQUIRED — the
# application refuses to start without them.

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# REQUIRED — your Atlas connection URI.
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=university_knowledge
# Connection pool sizes for the async Motor client.
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# -----------------------------------------------------------------------------
# MongoDB Atlas API (optional — only needed if you want automatic
# Vector Search / full-text index management at startup)
# -----------------------------------------------------------------------------
# Get these from https://cloud.mongodb.com/v2#/account/publicApi
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_PROJECT_ID=
ATLAS_CLUSTER_NAME=Cluster0

# -----------------------------------------------------------------------------
# Deepseek (LLM)
# -----------------------------------------------------------------------------
# REQUIRED — your Deepseek API key.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Security — JWT + CORS
# -----------------------------------------------------------------------------
# REQUIRED — random 32+ character secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-32-char-string!
# Algorithm is restricted to HS256 / HS384 / HS512 by the validator.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT iss/aud — pinned into every token we mint and required at decode.
JWT_ISSUER=raguni
JWT_AUDIENCE=raguni-api
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Email (Gmail SMTP) — used for password reset links
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Embeddings + chunking
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-large
VECTOR_DIMENSION=1024
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# XLSX uses smaller chunks so individual rows stay intact.
CHUNK_SIZE_XLSX=600
CHUNK_OVERLAP_XLSX=100

# -----------------------------------------------------------------------------
# Retrieval + RAG behaviour
# -----------------------------------------------------------------------------
VECTOR_INDEX_NAME=vector_index
FULLTEXT_INDEX_NAME=text_index
# Hybrid (vector + Atlas full-text RRF). Off by default — enable per
# deployment once the full-text index is tuned for your corpus.
USE_HYBRID_SEARCH=false
# Per-chunk cosine threshold; chunks below this are dropped before fusion.
VECTOR_SCORE_THRESHOLD=0.65
# If the best retrieved chunk scores below this, the answer is
# considered ungrounded and the no-answer response is sent instead
# of letting the LLM hallucinate.
NO_ANSWER_SCORE_THRESHOLD=0.55
# Top-K passed into the LLM. Bumped up because LLM-extracted
# schedule rows each become their own one-line chunk.
TOP_K_RESULTS=20
# Source-card preview length shown in the UI.
SOURCE_PREVIEW_MAX_CHARS=350
# Conversation context window passed to the LLM.
MAX_CONVERSATION_MESSAGES=10

# -----------------------------------------------------------------------------
# Upload / parser limits
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE=10485760
MAX_EXTRACTED_TEXT_SIZE=52428800

# -----------------------------------------------------------------------------
# Password reset
# -----------------------------------------------------------------------------
PASSWORD_RESET_EXPIRE_MINUTES=15

# -----------------------------------------------------------------------------
# Observability — environment, logging, Sentry, metrics
# -----------------------------------------------------------------------------
# "development" relaxes some fail-fast paths (see app/main.py).
ENVIRONMENT=development
LOG_FORMAT=text  # text | json
LOG_LEVEL=INFO
# Sentry — leave blank to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
RELEASE=
# Prometheus /metrics endpoint — off by default.
ENABLE_METRICS=false
