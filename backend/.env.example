# MongoDB Configuration
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=university_knowledge

# MongoDB Atlas API (Optional - for automatic Vector Search index creation)
# Get these from: https://cloud.mongodb.com/v2#/account/publicApi
ATLAS_PUBLIC_KEY=your_atlas_public_key
ATLAS_PRIVATE_KEY=your_atlas_private_key
ATLAS_PROJECT_ID=your_project_id
ATLAS_CLUSTER_NAME=Cluster0

# Deepseek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Security
SECRET_KEY=change-me-to-a-random-32-char-string!
CORS_ORIGINS=http://localhost:3000

# Application Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=intfloat/multilingual-e5-large
VECTOR_DIMENSION=1024
MAX_UPLOAD_SIZE=10485760
TOP_K_RESULTS=5
